---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main id="main-content">
    <div class="not-found-wrapper">
      <p class="eyebrow">Not found</p>
      <h1 aria-label="404 Not Found">404</h1>
      <p>The page you tried to open doesn’t live in this archive.</p>
      <LinkButton href="/" className="my-2">
        Go back home
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex max-w-3xl flex-1 items-center justify-center px-4 py-12;
  }
  .not-found-wrapper {
    @apply flex w-full flex-col items-center justify-center gap-4 border border-skin-line bg-skin-surface px-6 py-12 text-center sm:px-10 sm:py-16;
  }
  .not-found-wrapper h1 {
    @apply text-7xl font-semibold tracking-[-0.08em] text-skin-base sm:text-9xl;
  }
  .not-found-wrapper p {
    @apply max-w-xl text-base leading-8 text-skin-muted sm:text-lg;
  }
</style>
