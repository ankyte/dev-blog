---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import slugify from "@utils/slugify";
import { SOCIALS } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="hero-copy">
        <p class="eyebrow">Field notes</p>
        <h1>
          Writing through<br>
          <span>what I build.</span>
        </h1>
        <p class="hero-text">
          I'm Ankit, a software engineer at an asset management
          firm, writing about the practical side of
          building software. Essays, build notes, and things I wish someone had
          documented better.
        </p>
        <div class="hero-actions">
          Reach me at
          <LinkButton href="mailto:4nkitsahu@gmail.com" className="email-button">
            4nkitsahu@gmail.com
          </LinkButton>
        </div>
        {
          socialCount > 0 && (
            <div class="social-wrapper">
              <Socials />
            </div>
          )
        }
      </div>
    </section>

    <section id="recent-posts">
      <div class="section-heading">
        <p class="eyebrow">Latest</p>
        <h2>Recent writing</h2>
      </div>
      <ul>
        {
          sortedPosts.map(
            ({ data }, index) =>
              index < 4 && (
                <Card
                  href={`/posts/${slugify(data)}`}
                  frontmatter={data}
                  secHeading={false}
                />
              )
          )
        }
      </ul>
      <div class="all-posts-btn-wrapper">
        <LinkButton href="/posts">
          All Posts
          <svg xmlns="http://www.w3.org/2000/svg"
            ><path
              d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
            ></path>
          </svg>
        </LinkButton>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex w-full max-w-4xl flex-col gap-12 px-4 pb-14;
  }
  #hero {
    @apply border border-skin-line bg-skin-surface px-5 py-10 sm:px-8 sm:py-14;
  }
  .hero-copy {
    @apply flex max-w-4xl flex-col gap-6;
  }
  #hero h1 {
    @apply max-w-4xl text-5xl font-semibold tracking-[-0.06em] sm:text-7xl sm:leading-[0.94];
  }
  #hero h1 span {
    @apply text-skin-muted;
  }
  .hero-text {
    @apply max-w-4xl text-lg leading-10 text-skin-muted sm:leading-[1.55];
  }
  .hero-notes {
    @apply flex flex-wrap gap-3;
  }
  .hero-chip {
    @apply inline-flex items-center border px-3 py-1.5 font-mono text-[0.74rem] uppercase tracking-[0.18em];
  }
  .hero-chip-positive {
    border-color: rgb(6 95 70 / 0.9);
    color: rgb(94 234 212 / 0.92);
  }
  .hero-chip-muted {
    @apply border-skin-line text-skin-muted;
  }
  .hero-chip-warm {
    border-color: rgb(127 29 29 / 0.92);
    color: rgb(248 113 113 / 0.92);
  }
  .hero-actions {
    @apply mt-2 flex flex-col gap-3 sm:flex-row sm:items-center;
  }
  .email-button {
    @apply font-mono tracking-[0.02em];
  }
  .social-wrapper {
    @apply mt-3 pt-2;
  }

  #recent-posts {
    @apply flex flex-col gap-4;
  }
  .section-heading {
    @apply flex flex-col gap-2 border-b border-skin-muted pb-4;
  }
  #featured h2,
  #recent-posts h2 {
    @apply text-2xl font-semibold tracking-[-0.03em] sm:text-3xl;
  }
  .all-posts-btn-wrapper {
    @apply mt-2;
  }
</style>
