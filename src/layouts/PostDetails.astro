---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const { title, author, description, ogImage, canonicalURL, pubDatetime, tags } =
  post.data;

const { Content } = await post.render();

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/posts/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;
---

<Layout
  title={title}
  author={author}
  description={description}
  ogImage={ogUrl}
  canonicalURL={canonicalURL}
>
  <Header />
  <main id="main-content">
    <button
      class="focus-outline flex w-fit items-center gap-2 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-skin-muted hover:text-skin-accent sm:text-[0.72rem] sm:tracking-[0.22em]"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Back</span>
    </button>
    <section class="post-hero">
      <p class="eyebrow">Article</p>
      <h1 transition:name={slugifyStr(title)} class="post-title">{title}</h1>
      <Datetime datetime={pubDatetime} size="lg" className="mt-2" />
    </section>
    <article
      id="article"
      role="article"
      class="prose mx-auto w-full max-w-none border-y border-skin-line bg-skin-surface px-4 py-7 sm:max-w-3xl sm:border sm:px-8 sm:py-10"
    >
      <Content />
    </article>

    <ul class="tags-container">
      {tags.map(tag => <Tag name={slugifyStr(tag)} />)}
    </ul>
  </main>
  <Footer />
</Layout>

<style>
  main {
    @apply mx-auto flex w-full max-w-3xl flex-col gap-6 px-4 pb-12 sm:gap-8 sm:pb-14;
  }
  .post-hero {
    @apply w-full border-b border-skin-muted pb-6 sm:pb-8;
  }
  .post-title {
    @apply max-w-[16ch] text-3xl font-semibold leading-tight tracking-[-0.04em] text-skin-base sm:max-w-none sm:text-5xl;
  }
  .post-description {
    @apply max-w-2xl text-base leading-8 text-skin-muted sm:text-lg;
  }
  .tags-container {
    @apply flex flex-wrap gap-y-2 border-t border-skin-muted pt-4 sm:pt-5;
  }
</style>
