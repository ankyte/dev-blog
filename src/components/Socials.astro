---
import { SOCIALS } from "@config";
import socialIcons from "@assets/socialIcons";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;
---

<div class={`social-icons ${centered ? "flex" : ""}`}>
  {
    SOCIALS.filter(social => social.active).map(social => (
      <a
        href={social.href}
        class="social-link"
        title={social.linkTitle}
        aria-label={social.linkTitle}
      >
        <Fragment set:html={socialIcons[social.name]} />
      </a>
    ))
  }
</div>

<style>
  .social-icons {
    @apply flex flex-wrap items-center gap-3;
  }
  .social-link {
    @apply inline-flex h-9 w-9 items-center justify-center border text-skin-muted transition-colors duration-150 hover:border-skin-line hover:text-skin-base;
    border-color: transparent;
  }
</style>
