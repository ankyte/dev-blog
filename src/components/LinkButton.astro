---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
}

const { href, className, ariaLabel, title, disabled = false } = Astro.props;
---

<a
  href={disabled ? "#" : href}
  tabindex={disabled ? "-1" : "0"}
  class={`group interactive-border inline-flex items-center justify-center gap-2 bg-skin-surface px-3 py-2.5 text-sm font-medium tracking-[-0.02em] ${className}`}
  aria-label={ariaLabel}
  title={title}
  aria-disabled={disabled}
>
  <slot />
</a>

<style>
  a {
    @apply rounded-none hover:bg-skin-card hover:text-skin-accent;
  }
</style>
