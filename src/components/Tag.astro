---
export interface Props {
  name: string;
  size?: "sm" | "lg";
}

const { name, size = "sm" } = Astro.props;
---

<li
  class={`inline-block ${
    size === "sm" ? "my-1 mr-2" : "my-2 mr-3"
  }`}
>
  <a
    href={`/tags/${name.toLowerCase()}`}
    transition:name={name.toLowerCase()}
    class={`${size === "sm" ? "px-3 py-2 text-[0.72rem]" : "px-4 py-3 text-sm"} group inline-flex items-center gap-2 border border-skin-line bg-skin-surface font-mono uppercase tracking-[0.22em] text-skin-muted`}
  >
    <span>/</span>
    <span>{name.toLowerCase()}</span>
  </a>
</li>

<style>
  a {
    @apply transition-colors duration-150 hover:border-skin-accent hover:bg-skin-card hover:text-skin-accent;
  }
</style>
